# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=rafineri
DB_SSL=false
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=10000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=rafineri:

# Cache TTLs (in seconds)
REDIS_CACHE_TTL_HOT=60
REDIS_CACHE_TTL_MOST_VERIFIED=120
REDIS_CACHE_TTL_MOST_CONTESTED=120
REDIS_CACHE_TTL_NEWEST=60
REDIS_CACHE_TTL_DEFAULT=180
REDIS_CACHE_TTL_STORY=300
REDIS_CACHE_TTL_CATEGORIES=3600

# Security
ADMIN_TOKEN=your-secure-admin-token-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=1d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
