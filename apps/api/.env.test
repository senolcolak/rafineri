# Test Environment Configuration
NODE_ENV=test
PORT=3002

# Database (use test database)
DATABASE_URL=postgresql://rafineri:rafineri@localhost:5432/rafineri_test

# Redis
REDIS_URL=redis://localhost:6379/1

# Admin Token
ADMIN_TOKEN=test-admin-token

# Mock Mode (disable AI for tests)
MOCK_MODE=true
USE_LOCAL_AI=false

# Feature Flags
ENABLE_HN_INGESTION=false
ENABLE_REDDIT_INGESTION=false

# Logging
LOG_LEVEL=error
