# Environment
NODE_ENV=development
PORT=3000

# Mock Mode
# Set to true for deterministic mock scoring based on title hash
MOCK_MODE=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Database Configuration
DATABASE_URL=postgresql://user:pass@localhost:5432/rafineri

# HackerNews Configuration
HN_CONCURRENCY=5
HN_BATCH_SIZE=30

# Reddit Configuration
# Leave client credentials empty to skip Reddit ingestion gracefully
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=RafineriWorker/1.0
REDDIT_SUBREDDITS=technology,science,worldnews,news
REDDIT_LIMIT=25

# Clustering Configuration
CLUSTERING_SIMILARITY_THRESHOLD=0.75
CLUSTERING_TIME_WINDOW_HOURS=48

# Thumbnail Configuration
THUMBNAIL_TIMEOUT=5000
THUMBNAIL_PLACEHOLDER=https://via.placeholder.com/120x80?text=No+Image
THUMBNAIL_MAX_REDIRECTS=3
