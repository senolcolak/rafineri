# =============================================================================
# Rafineri Development Environment Configuration
# =============================================================================
# Copy this file to .env and generate secure values for production use
# =============================================================================

# === APP CONFIG ===
NODE_ENV=development
MOCK_MODE=true
NEXT_PUBLIC_API_TIMEOUT_MS=15000

# === ADMIN CREDENTIALS ===
# Generate secure admin password (min 16 chars recommended):
#   Linux/macOS: openssl rand -base64 24
#   Node.js: node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"
RAFINERI_ADMIN=admin
RAFINERI_ADMIN_PASSWORD=changeme
RAFINERI_ADMIN_URL=rafineri-secret-admin
# Public version for frontend (must match RAFINERI_ADMIN_URL)
NEXT_PUBLIC_RAFINERI_ADMIN_URL=rafineri-secret-admin

# === DATABASE ===
# Generate secure database password:
#   Linux/macOS: openssl rand -base64 32
#   Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATABASE_URL=postgresql://rafineri:rafineri@postgres:5432/rafineri

# === REDIS ===
REDIS_URL=redis://redis:6379

# === ADMIN TOKEN (API Security) ===
# Used for admin operations (rescore, etc.). Generate strong random token:
#   Linux/macOS: openssl rand -hex 32
#   Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   Python: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=dev-admin-token-change-in-production

# === REDDIT (optional - skip if not provided) ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=Rafineri/1.0

# === API KEYS (optional for real scoring) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_TIMEOUT_MS=15000
HN_REQUEST_TIMEOUT_MS=10000
REDDIT_REQUEST_TIMEOUT_MS=10000

# === WEB ===
NEXT_PUBLIC_API_URL=http://localhost:3001
