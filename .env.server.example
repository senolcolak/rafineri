# =============================================================================
# Rafineri Server Environment Configuration
# =============================================================================
# Copy this file to .env and update ALL values for your production deployment
# 
# SECURITY CHECKLIST:
#   [ ] Generated unique strong passwords for all services
#   [ ] Changed all default/changeme values
#   [ ] Restricted .env file permissions (chmod 600)
#   [ ] Configured HTTPS/TLS for public deployments
#   [ ] Reviewed CORS settings for API
# =============================================================================

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=rafineri

# Generate secure database password (32+ chars recommended):
#   Linux/macOS: openssl rand -base64 32
#   Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   Docker: docker run --rm alpine/openssl rand -base64 32
POSTGRES_PASSWORD=change-this-to-a-secure-password-32-chars-long

POSTGRES_DB=rafineri

# =============================================================================
# Application Mode
# =============================================================================
# Set to false to enable real LLM scoring (requires API keys below)
MOCK_MODE=true

# =============================================================================
# Admin Authentication
# =============================================================================
# Strong random token for admin operations (rescore, manage content, etc.)
# Generate with one of these commands:
#   Linux/macOS: openssl rand -hex 32
#   Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   Python: python3 -c "import secrets; print(secrets.token_hex(32))"
#   Docker: docker run --rm alpine/openssl rand -hex 32
ADMIN_TOKEN=generate-a-secure-random-token-min-32-chars

# =============================================================================
# Admin Panel Credentials (if different from default)
# =============================================================================
# Generate secure admin password:
#   Linux/macOS: openssl rand -base64 24
RUSTCHAT_ADMIN=admin
RUSTCHAT_ADMIN_PASSWORD=change-this-secure-admin-password

# =============================================================================
# Optional: Reddit Integration
# =============================================================================
# Leave empty to skip Reddit ingestion
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=Rafineri/1.0

# =============================================================================
# Optional: Real Scoring (when MOCK_MODE=false)
# =============================================================================
# Uncomment and set to enable real LLM scoring
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# Frontend
# =============================================================================
# Public URL for the API (used by browser)
# For local server deployment: http://your-server-ip:3001
# With reverse proxy: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================================================
# Security Headers (Optional - for advanced deployments)
# =============================================================================
# CORS_ORIGIN=https://yourdomain.com
# TRUST_PROXY=true  # Set if behind reverse proxy
