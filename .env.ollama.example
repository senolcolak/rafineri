# =============================================================================
# Rafineri Ollama Configuration
# =============================================================================
# Copy this file to .env and configure for local AI-powered news verification
#
# Usage with Docker Compose:
#   docker compose -f docker-compose.yml -f docker-compose.ollama.yml up -d
# =============================================================================

# === BASE CONFIG (same as .env.example) ===
NODE_ENV=production
MOCK_MODE=false

RAFINERI_ADMIN=admin
RAFINERI_ADMIN_PASSWORD=changeme
RAFINERI_ADMIN_URL=admin
NEXT_PUBLIC_RAFINERI_ADMIN_URL=admin

DATABASE_URL=postgresql://rafineri:rafineri@postgres:5432/rafineri
REDIS_URL=redis://redis:6379
ADMIN_TOKEN=dev-admin-token-change-in-production

# === OLLAMA AI CONFIGURATION ===
# Enable local AI for news verification
USE_LOCAL_AI=true

# Ollama server URL (internal Docker network)
OLLAMA_URL=http://ollama:11434

# AI Model for news verification (small, fast, good for factual analysis)
AI_MODEL=llama3.2:3b

# Embedding model for text similarity/clustering
EMBEDDING_MODEL=nomic-embed-text

# === EXTERNAL APIs (optional - not needed when using Ollama) ===
# Leave empty when using local AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === REDDIT (optional) ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=Rafineri/1.0

# === WEB ===
NEXT_PUBLIC_API_URL=http://localhost:3001
